# TEAL Enterprise — environment configuration
# Copy to .env.local and fill in. Never commit .env.local.

# Supabase project (hosted) or local `supabase start` values
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. NEVER expose to the browser. Used only in trusted server contexts.
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_NAME="TEAL Enterprise"
NEXT_PUBLIC_DEFAULT_BASE_CURRENCY=TTD
